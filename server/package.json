{
  "name": "portos-server",
  "version": "1.7.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch index.js",
    "start": "node index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --bail=1 --silent=passed-only --reporter=default --reporter=github-actions",
    "test:coverage": "vitest run --coverage",
    "setup:db:test": "node scripts/setup-db-test.mjs",
    "test:db": "vitest run --config vitest.config.db.js",
    "test:db:ci": "vitest run --config vitest.config.db.js --bail=1 --reporter=default --reporter=github-actions"
  },
  "dependencies": {
    "@googleapis/calendar": "^15.0.0",
    "@googleapis/gmail": "^17.0.0",
    "express": "5.2.1",
    "google-auth-library": "^10.7.0",
    "kokoro-js": "1.2.1",
    "node-pty": "1.2.0-beta.14",
    "pdf-lib": "^1.17.1",
    "pg": "8.22.0",
    "pm2": "7.0.3",
    "sharp": "0.35.3",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "undici": "^8.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.10",
    "vitest": "4.1.10"
  },
  "overrides": {
    "path-to-regexp": "8.4.2",
    "lodash": "4.18.1",
    "basic-ftp": "6.0.1",
    "follow-redirects": "1.16.0",
    "brace-expansion": "5.0.7",
    "body-parser": "2.3.0",
    "js-yaml": "4.3.0",
    "tar": "7.5.21",
    "engine.io": "6.6.9",
    "qs": "6.15.2",
    "sharp": "0.35.3",
    "socket.io-parser": "4.2.6",
    "protobufjs": "7.6.5",
    "@protobufjs/utf8": "1.1.1",
    "ws": "8.21.0",
    "ip-address": "10.2.0",
    "picomatch": "4.0.4",
    "postcss": "8.5.15",
    "systeminformation": "5.31.6"
  }
}
