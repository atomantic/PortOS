# Dependencies
node_modules/

# Build output
dist/
build/

# Runtime data (app registry, history, runs, migration state). Override the
# directory-level `data/` rule from the global ~/.gitignore so git descends
# into data/ and evaluates the negation below; then re-exclude everything
# inside except the .gitkeep that pins the empty directory. Seed/template
# content lives in data.reference/ and is copied in by scripts/setup-data.js;
# migration scripts live in scripts/migrations/.
!data/
data/*
!data/.gitkeep

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*

# Screenshots
*.png
!client/public/portos-logo.png
!client/public/sky/*.png
!docs/media/portos-logo.png
!data.reference/templates/*.png

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# PM2
.pm2/

# Playwright
.playwright-mcp

# Claude worktrees + session workflow scripts
.claude/workflows/
.claude/worktrees/
.worktrees/
.claude/settings.local.json
.claude/scheduled_tasks.lock

# BTW messages (ephemeral agent context, cleaned up after ingestion)
BTW.md

# Browser service node_modules (code is committed)
browser/node_modules/

# Browser service runtime data (CDP profiles, cache, downloads)
browser/data/

# Sub-package lock files. Root package.json does NOT declare these as
# workspaces (npm workspaces were reverted in b743222be — exFAT has no
# symlink support); `npm run setup` runs `npm install --prefix <pkg>` for
# each. client/ and server/ lockfiles ARE committed and CI installs them
# with `npm ci`: without them Dependabot only sees the ~45 deps declared in
# their package.json files and is blind to ~560 transitive packages, and
# every install/peer resolves a different tree. Only browser/ stays ignored
# (its node_modules is committed instead).
browser/package-lock.json
__pycache__/

# Temporary reference/scrape files created while building Freydis LoRA datasets
tmp/freydis*
tmp/portos-index.js
tmp/LoraDatasetDetail.js

# Runtime cache (e.g. projects.json) — regenerated, never committed
cache/

.antigravitycli
.superpowers/


tmp